# Development environment (remote dev DB, local web)
# Use a dedicated DEV database/project, never production.

# Database
DATABASE_URL="postgresql://postgres.DEV_PROJECT:DEV_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.DEV_PROJECT:DEV_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Auth
JWT_SECRET="dev-only-jwt-secret-change-me"

# Supabase (dev project)
SUPABASE_URL="https://DEV_PROJECT.supabase.co"
SUPABASE_ANON_KEY="dev-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="dev-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="element-library"

# CORS origin for local web
FRONTEND_URL="http://localhost:3000"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional
REDIS_URL="redis://localhost:6379"
KIE_FILE_UPLOAD_BASE_URL="https://kieai.redpandaai.co"
JSON_BODY_LIMIT="25mb"
URLENCODED_BODY_LIMIT="25mb"
