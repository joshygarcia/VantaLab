{
  "name": "@persona/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev -r dotenv/config --respawn --transpile-only src/main.ts",
    "dev:regen": "npm run prisma:generate && npm run dev",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:setup": "npm run prisma:generate && npm run prisma:push",
    "backfill:user-accounts": "node -r dotenv/config scripts/backfill-user-accounts.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.97.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.20",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.4.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
