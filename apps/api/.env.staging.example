# ─── Auth ────────────────────────────────────────────────────────────
JWT_SECRET="generate-a-strong-random-secret-here"

# ─── Firebase ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="vanta-lab-prod"
FIREBASE_STORAGE_BUCKET="vanta-lab-prod.firebasestorage.app"
# One of these must be set:
#   FIREBASE_SERVICE_ACCOUNT_PATH — path to the JSON key file (local dev)
#   FIREBASE_SERVICE_ACCOUNT_JSON — full JSON contents inline (Cloud Run secret)
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Optional bucket prefixes
FIREBASE_ELEMENT_LIBRARY_PREFIX="element-library"
FIREBASE_CREATOR_LAB_PREFIX="creator-lab-assets"

# Local emulator suite (uncomment for `firebase emulators:start`)
# FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
# FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
# FIREBASE_STORAGE_EMULATOR_HOST="127.0.0.1:9199"

# ─── Stripe Billing ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Kie.ai ──────────────────────────────────────────────────────────
KIE_FILE_UPLOAD_BASE_URL="https://kieai.redpandaai.co"

# ─── CORS / API ──────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
JSON_BODY_LIMIT="25mb"
URLENCODED_BODY_LIMIT="25mb"
