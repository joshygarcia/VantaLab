# ─── Firebase (Public — safe to commit to client bundles) ────────────
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="vanta-lab-prod.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="vanta-lab-prod"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="vanta-lab-prod.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxx"

# ─── Server-only Firebase admin (SSR session cookie verification) ────
# Provide one of these — JSON is preferred for Vercel; PATH for local.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIREBASE_SERVICE_ACCOUNT_PATH="../api/firebase-service-account.json"

# ─── API Gateway ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# ─── Stripe Billing (Public Key) ──────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Creator Lab character asset CDN (optional override) ─────────────
# NEXT_PUBLIC_CREATOR_LAB_ASSET_BASE_URL="https://storage.googleapis.com/vanta-lab-prod.firebasestorage.app/creator-lab-assets/character-options"

# ─── Dev-only (remove in production) ─────────────────────────────────
# NEXT_PUBLIC_DEV_JWT="paste-a-dev-jwt-here-for-local-testing"
