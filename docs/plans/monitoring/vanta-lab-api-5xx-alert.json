{
  "displayName": "Persona API 5xx Requests",
  "combiner": "OR",
  "enabled": true,
  "alertStrategy": {
    "notificationRateLimit": {
      "period": "300s"
    },
    "autoClose": "1800s"
  },
  "documentation": {
    "content": "Alert when Cloud Run serves 5xx responses for persona-api.",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "persona-api 5xx request log match",
      "conditionMatchedLog": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"persona-api\" AND httpRequest.status>=500"
      }
    }
  ]
}
