{
  "displayName": "Persona Billing Webhook 4xx/5xx",
  "combiner": "OR",
  "enabled": true,
  "alertStrategy": {
    "notificationRateLimit": {
      "period": "300s"
    },
    "autoClose": "1800s"
  },
  "documentation": {
    "content": "Alert when the Stripe webhook endpoint returns client or server errors.",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "billing webhook error response log match",
      "conditionMatchedLog": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"persona-api\" AND httpRequest.requestUrl:\"/api/v1/billing/stripe/webhook\" AND httpRequest.status>=400"
      }
    }
  ]
}
